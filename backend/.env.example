# --- Server ---
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Auth ---
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=11

# --- MongoDB (Prisma) ---
# Atlas: copy your SRV connection string and append a database name (e.g., /ledger)
# Example: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/ledger?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/ledger?retryWrites=true&w=majority

# --- RAG ---
RAG_SERVICE_URL=http://127.0.0.1:8000
